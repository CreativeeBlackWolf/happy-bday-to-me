{"config":{"lang":["en"],"separator":"[\\s\\-]+","pipeline":["stopWordFilter"]},"docs":[{"location":"","title":"\u0417\u0434\u0430\u0440\u043e\u0432\u0430. \u041f\u0440\u0438\u0432\u0435\u0442. \u3053\u3093\u306b\u3061\u306f","text":"<p>\u0425\u043e\u0447\u0435\u0448\u044c \u043f\u043e\u0441\u043c\u043e\u0442\u0440\u0435\u0442\u044c, \u0447\u0442\u043e \u0431\u0443\u0434\u0435\u0442 \u0438\u0437 \u043d\u0430\u043f\u0438\u0442\u043a\u043e\u0432? \u041f\u043e\u0441\u043c\u043e\u0442\u0440\u0438 \u043c\u0435\u043d\u044e</p> <p>\u0415\u0441\u043b\u0438 \u0445\u043e\u0447\u0435\u0448\u044c, \u043c\u043e\u0436\u0435\u0448\u044c \u043e\u0441\u0442\u0430\u0432\u0438\u0442\u044c \u043c\u043d\u0435 \u0441\u0432\u043e\u0451 \u043f\u043e\u0436\u0435\u043b\u0430\u043d\u0438\u0435 \u0437\u0434\u0435\u0441\u044c</p>"},{"location":"menu/","title":"\u041c\u0435\u043d\u044e","text":"<p>\u0414\u0430-\u0434\u0430. \u041d\u0430\u043f\u0438\u0442\u043a\u0438 \u0438 \u0435\u0434\u0430 \u0431\u0443\u0434\u0443\u0442 \u0437\u0434\u0435\u0441\u044c \u0437\u0430\u0440\u0430\u043d\u0435\u0435 \u043e\u043f\u0440\u0435\u0434\u0435\u043b\u0435\u043d\u044b. \u041c\u043e\u0436\u0435\u0448\u044c \u0434\u0430\u0436\u0435 \u0432\u044b\u0431\u0440\u0430\u0442\u044c \u0441\u0440\u0430\u0437\u0443, \u0447\u0442\u043e\u0431\u044b \u043f\u043e\u0442\u043e\u043c \u0434\u043e\u043b\u0433\u043e \u043d\u0435 \u043c\u0443\u0447\u0430\u0442\u044c\u0441\u044f \u0441 \u0432\u044b\u0431\u043e\u0440\u043e\u043c.</p> <p>\u041d\u043e \u043d\u0435 \u0432\u0441\u0451 \u0438 \u043d\u0435 \u0441\u0440\u0430\u0437\u0443. \u0411\u043b\u0438\u0436\u0435 \u043a \u043c\u0435\u0440\u043e\u043f\u0440\u0438\u044f\u0442\u0438\u044e \u0437\u0434\u0435\u0441\u044c \u0431\u0443\u0434\u0435\u0442 \u043f\u043e\u043b\u043d\u044b\u0439 \u0441\u043f\u0438\u0441\u043e\u043a \u0442\u043e\u0433\u043e, \u0447\u0442\u043e \u0442\u044b \u043c\u043e\u0436\u0435\u0448\u044c \u043f\u043e\u043f\u0440\u043e\u0431\u043e\u0432\u0430\u0442\u044c \u0438\u0437 \u043c\u043e\u0438\u0445 \u043a\u0440\u0438\u0432\u044b\u0445 \u0440\u0443\u043a.</p> <p>\u0412\u0441\u0435 \u0441\u0442\u0430\u043a\u0430\u043d\u044b \u043f\u043e 185 \u043c\u043b.</p> <p>\u0412\u0441\u0451, \u0447\u0442\u043e \u0435\u0441\u0442\u044c \u043d\u0438\u0436\u0435, \u043c\u043e\u0436\u0435\u0442 \u0412\u041d\u0415\u0417\u0410\u041f\u041d\u041e \u043f\u043e\u043c\u0435\u043d\u044f\u0442\u044c\u0441\u044f.</p>"},{"location":"menu/#_2","title":"\u0421\u0438\u0440\u043e\u043f\u044b","text":"<p>\u0414\u043e\u0441\u0442\u0443\u043f\u043d\u043e 3 \u0441\u0438\u0440\u043e\u043f\u0430: \u0411\u043b\u044e-\u041a\u044e\u0440\u0430\u0441\u0430\u043e, \u041c\u0430\u0440\u0430\u043a\u0443\u0439\u044f \u0438 \u0413\u0440\u0435\u043d\u0430\u0434\u0438\u043d.</p>"},{"location":"menu/#_3","title":"\ud83c\udf78 \u041a\u043e\u043a\u0442\u0435\u0439\u043b\u0438","text":""},{"location":"menu/#_4","title":"~~\u0420\u0430\u043d\u0434\u043e\u043c~~","text":"<p>\u0421\u043b\u0443\u0447\u0430\u0439\u043d\u044b\u0439 \u043a\u043e\u043a\u0442\u0435\u0439\u043b\u044c \u0438\u0437 \u0441\u043b\u0443\u0447\u0430\u0439\u043d\u044b\u0445 \u0438\u043d\u0433\u0440\u0438\u0434\u0438\u0435\u043d\u0442\u043e\u0432. \u0418 \u0432\u0441\u044e \u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0441\u0442\u044c \u0437\u0430 \u0432\u044b\u0431\u0440\u0430\u043d\u043d\u044b\u0435 \u0432\u0441\u043b\u0435\u043f\u0443\u044e \u043d\u0430\u043f\u0438\u0442\u043a\u0438 \u0431\u0443\u0434\u0435\u0448\u044c \u043d\u0435\u0441\u0442\u0438 \u0438\u043c\u0435\u043d\u043d\u043e \u0442\u044b.</p>"},{"location":"menu/#_5","title":"\u041e\u0442\u0432\u0451\u0440\u0442\u043a\u0430","text":"<p>\u041a\u043b\u0430\u0441\u0441\u0438\u043a\u0430 \u043a\u043b\u0430\u0441\u0441\u0438\u043a.</p> <p>\u0421\u043e\u0441\u0442\u0430\u0432:</p> <ul> <li><code>\u0412\u043e\u0434\u043a\u0430</code></li> <li><code>\u0410\u043f\u0435\u043b\u044c\u0441\u0438\u043d\u043e\u0432\u044b\u0439 \u0441\u043e\u043a</code></li> </ul>"},{"location":"menu/#-","title":"\u0412\u0438\u0441\u043a\u0438-\u043a\u043e\u043b\u0430","text":"<p>\u0421\u043e\u0441\u0442\u0430\u0432 (\u0432\u043d\u0435\u0437\u0430\u043f\u043d\u043e):</p> <ul> <li><code>\u0412\u0438\u0441\u043a\u0438</code></li> <li><code>\u041a\u043e\u043b\u0430</code></li> </ul>"},{"location":"menu/#_6","title":"\u041a\u043e\u0441\u043c\u043e\u043f\u043e\u043b\u0438\u0442\u0435\u043d","text":"<p>\u0421\u043e\u0441\u0442\u0430\u0432:</p> <ul> <li><code>\u041b\u0438\u043c\u043e\u043d\u043d\u0430\u044f \u0432\u043e\u0434\u043a\u0430</code> \u0418\u041b\u0418 <code>\u0412\u043e\u0434\u043a\u0430 \u0438 \u043b\u0438\u043c\u043e\u043d\u043d\u044b\u0439 \u0441\u043e\u043a</code> (\u0441\u043c\u043e\u0442\u0440\u044f \u0447\u0442\u043e \u043d\u0430\u0439\u0434\u0451\u0442\u0441\u044f)</li> <li><code>\u0410\u043f\u0435\u043b\u044c\u0441\u0438\u043d\u043e\u0432\u044b\u0439 \u043b\u0438\u043a\u0451\u0440</code></li> <li><code>\u0411\u043b\u044e-\u043a\u044e\u0440\u0430\u0441\u0430\u043e</code></li> <li><code>\u041a\u043b\u044e\u043a\u0432\u0435\u043d\u043d\u044b\u0439 \u0441\u043e\u043a</code></li> </ul>"},{"location":"menu/#_7","title":"\u041a\u0440\u043e\u0432\u0430\u0432\u0430\u044f \u043c\u044d\u0440\u0438 (\u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e)","text":"<p>\u0421\u043e\u0441\u0442\u0430\u0432:</p> <ul> <li><code>\u0422\u043e\u043c\u0430\u0442\u043d\u044b\u0439 \u0441\u043e\u043a</code></li> <li><code>\u041e\u0441\u0442\u0440\u044b\u0439 \u0441\u043e\u0443\u0441</code></li> <li><code>\u0412\u043e\u0434\u043a\u0430</code></li> <li><code>\u0421\u043e\u043b\u044c</code></li> <li><code>\u041f\u0435\u0440\u0435\u0446</code></li> </ul>"},{"location":"menu/#_8","title":"\u041a\u043e\u0440\u043e\u043b\u0435\u0432\u0441\u043a\u0438\u0439 \u043a\u0440\u0435\u0441\u0442","text":"<p>\u0421\u043e\u0441\u0442\u0430\u0432:</p> <ul> <li><code>\u0412\u0435\u0440\u043c\u0443\u0442</code></li> <li><code>\u0412\u0438\u0441\u043a\u0438</code></li> <li><code>\u041b\u0438\u043a\u0451\u0440</code></li> <li><code>\u041b\u0438\u043c\u043e\u043d\u043d\u044b\u0439 \u0441\u043e\u043a</code></li> </ul>"},{"location":"menu/#_9","title":"\u0411\u044c\u044f\u043d\u043a\u043e \u0421\u0430\u043d\u0440\u0430\u0439\u0437","text":"<p>\u0421\u043e\u0441\u0442\u0430\u0432:</p> <ul> <li><code>\u0412\u0435\u0440\u043c\u0443\u0442</code></li> <li><code>\u0410\u043f\u0435\u043b\u044c\u0441\u0438\u043d\u043e\u0432\u044b\u0439 \u0441\u043e\u043a</code></li> <li><code>\u041a\u043b\u044e\u043a\u0432\u0435\u043d\u043d\u044b\u0439 \u0441\u043e\u043a</code></li> </ul>"},{"location":"menu/#_10","title":"\ud83c\udf7a \u041f\u0438\u0432\u043e","text":"<p>\u041c\u043e\u0436\u0435\u0448\u044c \u0442\u0430\u043a\u0436\u0435 \u0434\u043e\u0431\u0430\u0432\u0438\u0442\u044c \u0441\u0438\u0440\u043e\u043f, \u0442\u0430\u043a \u0431\u0443\u0434\u0435\u0442 \u0432\u043a\u0443\u0441\u043d\u0435\u0435</p> <ul> <li>Bud</li> <li>Kozel</li> </ul>"},{"location":"foryou/4akseniy/","title":"\u042d\u0442\u043e \u0442\u0435\u0431\u0435, \u0421\u0435\u043d\u044f.","text":"<p>\u042d\u0442\u043e\u0433\u043e \u043d\u0438\u043a\u0442\u043e \u043d\u0435 \u0443\u0432\u0438\u0434\u0438\u0442, \u0442\u043e\u043b\u044c\u043a\u043e \u0435\u0441\u043b\u0438 \u0442\u044b \u043d\u0435 \u043f\u0435\u0440\u0435\u0448\u043b\u0451\u0448\u044c.</p> <p>\u0414\u0430-\u0434\u0430, \u044d\u0442\u043e \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u044c\u043d\u043e \u0434\u043b\u044f \u0442\u0435\u0431\u044f. \u0414\u0430, \u044d\u0442\u043e \u043d\u0435 \u0430\u043d\u0430\u043b\u043e\u0433\u043e\u0432\u044b\u0439 \u0444\u043e\u0440\u043c\u0430\u0442 \u0440\u0430\u0437\u0433\u043e\u0432\u043e\u0440\u0430 \u0442\u0435\u0442-\u0430-\u0442\u0435\u0442, \u0430, \u0441\u043a\u043e\u0440\u0435\u0435, \u043f\u0440\u043e\u0441\u0442\u043e \u043f\u0438\u0441\u044c\u043c\u043e. \u0425\u0443\u0436\u0435, \u0447\u0435\u043c \u0441\u043a\u0430\u0437\u0430\u0442\u044c \u0432 \u043b\u0438\u0446\u043e, \u043d\u043e \u043b\u0443\u0447\u0448\u0435, \u0447\u0435\u043c \u043d\u0435 \u0441\u043a\u0430\u0437\u0430\u0442\u044c \u043d\u0438\u0447\u0435\u0433\u043e, \u043d\u0435 \u0442\u0430\u043a \u043b\u0438?</p>"},{"location":"foryou/4akseniy/#_2","title":"\u041f\u043e\u0447\u0435\u043c\u0443 \u0442\u044b \u043f\u0440\u0438\u0433\u043b\u0430\u0448\u0451\u043d?","text":"<p>\u041f\u043e\u0442\u043e\u043c\u0443 \u0447\u0442\u043e \u0442\u044b \u0442\u043e\u0442 \u0447\u0435\u043b\u043e\u0432\u0435\u043a, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u0441\u043f\u043e\u0441\u043e\u0431\u0435\u043d \u0437\u0430\u0434\u0430\u0432\u0430\u0442\u044c \u0442\u043e\u043d \u0432\u0441\u0435\u0439 \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u0438.</p> <p>\u041f\u043e\u0442\u043e\u043c\u0443 \u0447\u0442\u043e \u0442\u044b \u0431\u0435\u0437\u0443\u043c\u043d\u043e \u0440\u0430\u0431\u043e\u0442\u043e\u0441\u043f\u043e\u0441\u043e\u0431\u043d\u044b\u0439 \u0447\u0435\u043b\u043e\u0432\u0435\u043a, \u0438 \u0445\u043e\u0447\u0435\u0442\u0441\u044f, \u0447\u0442\u043e\u0431\u044b \u0442\u044b \u0432\u0441\u0451-\u0442\u0430\u043a\u0438 \u043d\u0435\u043c\u043d\u043e\u0433\u043e \u043f\u0435\u0440\u0435\u0434\u043e\u0445\u043d\u0443\u043b \u0432 \u043f\u0440\u0438\u044f\u0442\u043d\u043e\u0439 \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u0438.</p> <p>\u041f\u043e\u0442\u043e\u043c\u0443 \u0447\u0442\u043e \u044f \u0442\u0435\u0431\u044f \u0441\u0447\u0438\u0442\u0430\u044e \u0431\u0435\u0437\u0443\u043c\u043d\u043e \u0445\u0430\u0440\u0438\u0437\u043c\u0430\u0442\u0438\u0447\u043d\u044b\u043c, \u0434\u0430 \u0438 \u0432 \u0446\u0435\u043b\u043e\u043c \u043f\u0438\u0437\u0434\u0430\u0442\u044b\u043c \u0447\u0435\u043b\u043e\u0432\u0435\u043a\u043e\u043c. \u0414\u0430 \u0438, \u0447\u0435\u0441\u0442\u043d\u043e \u0433\u043e\u0432\u043e\u0440\u044f, \u044f \u0432\u0441\u0435\u0433\u0434\u0430 \u0442\u0430\u043a \u0441\u0447\u0438\u0442\u0430\u043b. \u041b\u0438\u0447\u043d\u043e \u043c\u043d\u0435 \u0431\u044b \u0445\u043e\u0442\u0435\u043b\u043e\u0441\u044c \u0447\u0430\u0449\u0435 \u0441 \u0442\u043e\u0431\u043e\u0439 \u043e\u0431\u0449\u0430\u0442\u044c\u0441\u044f, \u043d\u043e \u044f \u043b\u0438\u0431\u043e \u0437\u0430\u0431\u044b\u0432\u0430\u044e \u043d\u0430\u0433\u043b\u0443\u0445\u043e, \u043b\u0438\u0431\u043e \u0434\u0430.</p> <p>\u041f\u043e\u0441\u043b\u0443\u0448\u0430\u0439 \u041e\u0421\u0422 \u0438\u0437 RoR2, \u0441\u0443\u043a\u0430.</p> <p>\u0412\u0441\u0435\u0445 \u0431\u043b\u0430\u0433, \u0436\u0434\u0443 \u043d\u0430 \u0434\u0440.</p>"},{"location":"foryou/4danila/","title":"\u042d\u0442\u043e \u0442\u0435\u0431\u0435, \u0414\u0430\u043d\u0438\u043b\u0430.","text":"<p>\u042d\u0442\u043e\u0433\u043e \u043d\u0438\u043a\u0442\u043e \u043d\u0435 \u0443\u0432\u0438\u0434\u0438\u0442, \u0442\u043e\u043b\u044c\u043a\u043e \u0435\u0441\u043b\u0438 \u0442\u044b \u043d\u0435 \u043f\u0435\u0440\u0435\u0448\u043b\u0451\u0448\u044c.</p> <p>\u0414\u0430-\u0434\u0430, \u044d\u0442\u043e \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u044c\u043d\u043e \u0434\u043b\u044f \u0442\u0435\u0431\u044f.</p>"},{"location":"foryou/4danila/#_2","title":"\u041f\u043e\u0447\u0435\u043c\u0443 \u0442\u044b \u043f\u0440\u0438\u0433\u043b\u0430\u0448\u0451\u043d?","text":"<p>\u041f\u043e\u0442\u043e\u043c\u0443 \u0447\u0442\u043e \u0442\u044b \u043c\u043e\u0436\u0435\u0448\u044c \u043f\u043e\u043c\u043e\u0433\u0430\u0442\u044c \u043c\u043d\u0435 \u0440\u0430\u0437\u043b\u0438\u0432\u0430\u0442\u044c \u043d\u0430\u043f\u0438\u0442\u043a\u0438. \u042f \u0440\u0430\u0437\u0440\u0435\u0448\u0430\u044e.</p> <p>\u041f\u043e\u0442\u043e\u043c\u0443 \u0447\u0442\u043e \u0432 \u0446\u0435\u043b\u043e\u043c \u0445\u043e\u0442\u0435\u043b\u043e\u0441\u044c \u0431\u044b \u043e\u0431\u0449\u0430\u0442\u044c\u0441\u044f \u0441 \u0442\u043e\u0431\u043e\u0439 \u043f\u043e\u0447\u0430\u0449\u0435, \u0438\u0431\u043e \u044f \u0441\u0447\u0438\u0442\u0430\u044e \u0442\u0435\u0431\u044f \u0432\u043f\u043e\u043b\u043d\u0435 \u0441\u0435\u0431\u0435 \u043f\u0440\u0438\u044f\u0442\u043d\u044b\u043c \u0447\u0435\u043b\u043e\u0432\u0435\u043a\u043e\u043c.</p> <p>\u0410 \u0431\u043e\u043b\u044c\u0448\u0435-\u0442\u043e \u0441\u043a\u0430\u0437\u0430\u0442\u044c \u0438 \u043d\u0435\u0447\u0435\u0433\u043e...</p> <p>\u0412\u0441\u0435\u0445 \u0431\u043b\u0430\u0433. \u0416\u0434\u0443 \u043d\u0430 \u0414\u0420.</p>"},{"location":"foryou/4deymass/","title":"\u042d\u0442\u043e \u0442\u0435\u0431\u0435, \u0421\u0442\u0430\u0440\u044b\u0439.","text":"<p>\u042d\u0442\u043e\u0433\u043e \u043d\u0438\u043a\u0442\u043e \u043d\u0435 \u0443\u0432\u0438\u0434\u0438\u0442, \u0442\u043e\u043b\u044c\u043a\u043e \u0435\u0441\u043b\u0438 \u0442\u044b \u043d\u0435 \u043f\u0435\u0440\u0435\u0448\u043b\u0451\u0448\u044c.</p> <p>\u0414\u0430-\u0434\u0430, \u044d\u0442\u043e \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u044c\u043d\u043e \u0434\u043b\u044f \u0442\u0435\u0431\u044f.</p>"},{"location":"foryou/4deymass/#_2","title":"\u041f\u043e\u0447\u0435\u043c\u0443 \u0442\u044b \u043f\u0440\u0438\u0433\u043b\u0430\u0448\u0451\u043d?","text":"<p>\u041f\u043e\u0442\u043e\u043c\u0443 \u0447\u0442\u043e \u044f \u0441\u0440\u0430\u0432\u043d\u0438\u0442\u0435\u043b\u044c\u043d\u043e \u0434\u0430\u0432\u043d\u043e \u0442\u0435\u0431\u044f \u0437\u043d\u0430\u044e \u0438 \u0445\u043e\u0447\u0443 \u0432\u0438\u0434\u0435\u0442\u044c \u043d\u0430 \u0441\u0432\u043e\u0451\u043c \u0414\u0420.</p> <p>\u041f\u043e\u0442\u043e\u043c\u0443 \u0447\u0442\u043e \u043c\u044b \u0441 \u0442\u043e\u0431\u043e\u0439 \u0441\u043e\u0432\u043c\u0435\u0441\u0442\u043d\u043e \u043d\u0435 \u0431\u0443\u0445\u0430\u043b\u0438, \u0430 \u0432\u043e\u043e\u0431\u0449\u0435-\u0442\u043e \u0445\u043e\u0447\u0435\u0442\u0441\u044f \u043e\u0447\u0435\u043d\u044c \u0445\u043e\u0447\u0435\u0442\u0441\u044f.</p> <p>\u041f\u043e\u0442\u043e\u043c\u0443 \u0447\u0442\u043e \u0442\u044b \u0432 \u0446\u0435\u043b\u043e\u043c \u043f\u0440\u0438\u044f\u0442\u043d\u044b\u0439 \u0447\u0435\u043b\u043e\u0432\u0435\u043a, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u0432 \u043f\u043e\u0441\u043b\u0435\u0434\u043d\u0438\u0435 \u043c\u0435\u0441\u044f\u0446\u044b \u043f\u0440\u0438\u0443\u043a\u0440\u0430\u0441\u0438\u043b \u043c\u043e\u0451 \u0441\u043a\u0443\u0447\u043d\u043e\u0435 \u0432\u0440\u0435\u043c\u044f\u043f\u0440\u043e\u0432\u043e\u0436\u0434\u0435\u043d\u0438\u0435. \u041c\u043e\u044f \u043e\u0447\u0435\u0440\u0435\u0434\u044c, \u0442\u0430\u043a \u0441\u043a\u0430\u0437\u0430\u0442\u044c.</p> <p>\u041f\u0438\u0442\u044c \u043c\u043d\u043e\u0433\u043e \u0440\u0430\u0437\u0440\u0435\u0448\u0430\u044e.</p> <p>\u0412\u0441\u0435\u0445 \u0431\u043b\u0430\u0433. \u0416\u0434\u0443 \u043d\u0430 \u0414\u0420.</p>"},{"location":"foryou/4eeeegor/","title":"\u042d\u0442\u043e \u0442\u0435\u0431\u0435, \u0415\u0433\u043e\u0440\u044b\u0447.","text":"<p>\u042d\u0442\u043e\u0433\u043e \u043d\u0438\u043a\u0442\u043e \u043d\u0435 \u0443\u0432\u0438\u0434\u0438\u0442, \u0442\u043e\u043b\u044c\u043a\u043e \u0435\u0441\u043b\u0438 \u0442\u044b \u043d\u0435 \u043f\u0435\u0440\u0435\u0448\u043b\u0451\u0448\u044c.</p> <p>\u0414\u0430-\u0434\u0430, \u044d\u0442\u043e \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u044c\u043d\u043e \u0434\u043b\u044f \u0442\u0435\u0431\u044f. \u041d\u0435 \u0441\u043f\u0440\u0430\u0448\u0438\u0432\u0430\u0439 \u043b\u0438\u0448\u043d\u0438\u0439 \u0440\u0430\u0437 \u0437\u0430\u0447\u0435\u043c, \u043d\u0430\u0445\u0443\u044f \u0438 \u0447\u0442\u043e.</p>"},{"location":"foryou/4eeeegor/#_2","title":"\u041f\u043e\u0447\u0435\u043c\u0443 \u0442\u044b \u043f\u0440\u0438\u0433\u043b\u0430\u0448\u0451\u043d?","text":"<p>\u041f\u043e\u0442\u043e\u043c\u0443 \u044f \u0434\u0430\u0432\u043d\u043e \u0445\u043e\u0442\u0435\u043b \u0443\u0441\u0442\u0440\u043e\u0438\u0442\u044c \u043f\u043e\u0434\u043e\u0431\u043d\u0443\u044e \u0442\u0443\u0441\u0443, \u0438 \u043f\u0440\u0438\u0433\u043b\u0430\u0441\u0438\u0442\u044c \u0442\u0435\u0431\u044f \u0442\u0443\u0434\u0430.</p> <p>\u041f\u043e\u0442\u043e\u043c\u0443 \u0447\u0442\u043e \u0442\u044b \u0443\u0435\u0437\u0436\u0430\u0435\u0448\u044c, \u0438 \u043b\u0443\u0447\u0448\u0435 \u0448\u0430\u043d\u0441\u0430 \u043f\u0440\u043e\u0432\u0435\u0441\u0442\u0438 \u0432\u0440\u0435\u043c\u044f \u0442\u0430\u043a, \u043a\u0430\u043a \u044f \u0431\u044b \u0445\u043e\u0442\u0435\u043b, \u0434\u0430\u043b\u044c\u0448\u0435 \u0443\u0436\u0435 \u043d\u0435 \u0431\u0443\u0434\u0435\u0442.</p> <p>\u041d\u0435 \u043d\u0430\u0436\u0438\u0440\u0430\u0439\u0441\u044f \u0441\u0438\u043b\u044c\u043d\u043e \u0438 \u043d\u0435 \u0443\u0441\u0442\u0440\u0430\u0438\u0432\u0430\u0439 \u0434\u0435\u0431\u043e\u0448. \u042f \u043f\u0440\u043e\u0441\u043b\u0435\u0436\u0443 \u0437\u0430 \u0442\u043e\u0431\u043e\u0439. </p> <p>\u0412\u0441\u0435\u0445 \u0431\u043b\u0430\u0433. \u0416\u0434\u0443 \u043d\u0430 \u0414\u0420.</p>"},{"location":"foryou/4hex/","title":"\u042d\u0442\u043e \u0442\u0435\u0431\u0435, hex.","text":"<p>\u042d\u0442\u043e\u0433\u043e \u043d\u0438\u043a\u0442\u043e \u043d\u0435 \u0443\u0432\u0438\u0434\u0438\u0442, \u0442\u043e\u043b\u044c\u043a\u043e \u0435\u0441\u043b\u0438 \u0442\u044b \u043d\u0435 \u043f\u0435\u0440\u0435\u0448\u043b\u0451\u0448\u044c.</p> <p>\u0414\u0430-\u0434\u0430, \u044d\u0442\u043e \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u044c\u043d\u043e \u0434\u043b\u044f \u0442\u0435\u0431\u044f. \u0415\u0441\u0442\u044c \u0432\u0435\u0440\u043e\u044f\u0442\u043d\u043e\u0441\u0442\u044c, \u0447\u0442\u043e \u0442\u044b \u044d\u0442\u043e \u043f\u0440\u043e\u0441\u0442\u043e \u043f\u0440\u043e\u0438\u0433\u043d\u043e\u0440\u0438\u0440\u0443\u0435\u0448\u044c \u0438\u043b\u0438 \u0441\u043a\u0430\u0436\u0435\u0448\u044c \u043f\u0440\u043e \u0441\u0435\u0431\u044f \u0447\u0442\u043e-\u0442\u043e \u0432\u0440\u043e\u0434\u0435 <code>\u043e\u043f\u044f\u0442\u044c \u044d\u0442\u043e\u0442 \u0434\u043e\u043b\u0431\u043e\u0451\u0431\u0438\u043a \u043c\u0435\u043d\u044f \u043f\u044b\u0442\u0430\u0435\u0442\u0441\u044f \u0437\u0430\u043c\u0430\u043d\u0438\u0442\u044c/\u0441\u0442\u0430\u043b\u043a\u0435\u0440\u0438\u0442\u044c/&lt;\u0432\u0441\u0442\u0430\u0432\u0438\u0442\u044c_\u043d\u0443\u0436\u043d\u043e\u0435&gt;</code>. \u042f \u0431\u044b \u044d\u0442\u043e\u0433\u043e, \u043a\u043e\u043d\u0435\u0447\u043d\u043e, \u043d\u0435 \u0445\u043e\u0442\u0435\u043b, \u043d\u043e \u044d\u0442\u043e \u0442\u0432\u043e\u0451 \u043f\u0440\u0430\u0432\u043e.</p>"},{"location":"foryou/4hex/#_1","title":"\u041f\u043e\u0447\u0435\u043c\u0443 \u0442\u044b \u043f\u0440\u0438\u0433\u043b\u0430\u0448\u0435\u043d\u0430?","text":"<p>\u041f\u043e\u0442\u043e\u043c\u0443 \u0447\u0442\u043e \u044f \u043f\u0440\u0438\u0433\u043b\u0430\u0448\u0430\u044e \u0442\u0435\u0445, \u043a\u0442\u043e \u0434\u043b\u044f \u043c\u0435\u043d\u044f \u0445\u043e\u0442\u044c \u0441\u043a\u043e\u043b\u044c\u043a\u043e-\u0442\u043e \u0432\u0430\u0436\u0435\u043d.</p> <p>\u041f\u043e\u0442\u043e\u043c\u0443 \u0447\u0442\u043e \u044d\u0442\u043e \u043c\u0435\u0440\u043e\u043f\u0440\u0438\u044f\u0442\u0438\u0435 \u044f \u0445\u043e\u0447\u0443 \u0441\u0434\u0435\u043b\u0430\u0442\u044c \u043e\u0431\u0449\u0438\u043c, \u0430 \u043d\u0435 \u0441\u0432\u043e\u0438\u043c. \u042f \u0445\u043e\u0447\u0443, \u0447\u0442\u043e\u0431\u044b \u043b\u044e\u0434\u0438, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043f\u0440\u0438\u0435\u0434\u0443\u0442 \u043d\u0430 \u0441\u0435\u0439 \u043f\u0440\u0430\u0437\u0434\u043d\u0438\u043a, \u043e\u0442\u0434\u043e\u0445\u043d\u0443\u043b\u0438 \u043e\u0442 \u0441\u0443\u0435\u0442\u044b \u0440\u043e\u0432\u043d\u043e \u043d\u0430\u0441\u0442\u043e\u043b\u044c\u043a\u043e, \u043d\u0430\u0441\u043a\u043e\u043b\u044c\u043a\u043e \u043e\u043d\u0438 \u0441\u0435\u0431\u0435 \u043c\u043e\u0433\u0443\u0442 \u043f\u043e\u0437\u0432\u043e\u043b\u0438\u0442\u044c \u0437\u0434\u0435\u0441\u044c \u0438 \u0441\u0435\u0439\u0447\u0430\u0441. \u0414\u0430 \u0438 \u0435\u0441\u043b\u0438 \u0435\u0441\u0442\u044c \u043f\u043e\u0432\u043e\u0434, \u0442\u043e \u043a\u0430\u043a \u043e\u0442\u043a\u0430\u0437\u0430\u0442\u044c\u0441\u044f-\u0442\u043e?</p> <p>\u041f\u043e\u0442\u043e\u043c\u0443 \u0447\u0442\u043e, \u0435\u0441\u043b\u0438 \u0431\u044b\u0442\u044c \u043e\u0442\u043a\u0440\u043e\u0432\u0435\u043d\u043d\u044b\u043c, \u044f \u043d\u0435 \u0445\u043e\u0447\u0443 \u0438\u043c\u0435\u0442\u044c \u043a\u0430\u043a\u0438\u0445-\u043b\u0438\u0431\u043e \u043d\u0435\u0433\u0430\u0442\u0438\u0432\u043d\u044b\u0445 \u043e\u0442\u043d\u043e\u0448\u0435\u043d\u0438\u0439 \u0441 \u043b\u044e\u0434\u044c\u043c\u0438. \u0412 \u0442\u043e\u043c \u0447\u0438\u0441\u043b\u0435 \u0438 \u0441 \u0442\u043e\u0431\u043e\u0439. \u042f \u043c\u043e\u0433\u0443 \u043f\u043e\u043f\u044b\u0442\u0430\u0442\u044c\u0441\u044f \u043f\u043e\u043d\u044f\u0442\u044c \u0438 \u0442\u0432\u043e\u0439 \u0443\u0440\u043e\u0432\u0435\u043d\u044c \u043d\u0435\u0433\u043e\u0434\u043e\u0432\u0430\u043d\u0438\u044f, \u043d\u043e \u0438 \u0442\u044b \u043c\u0435\u043d\u044f \u043f\u043e\u0439\u043c\u0438. \u041c\u043e\u0436\u0435\u0448\u044c \u0441\u0447\u0438\u0442\u0430\u0442\u044c, \u0447\u0442\u043e \u044d\u0442\u043e \u0441\u043f\u043e\u0441\u043e\u0431 \u0443\u043b\u0443\u0447\u0448\u0438\u0442\u044c \u043e\u0442\u043d\u043e\u0448\u0435\u043d\u0438\u0435 \u043a\u043e \u043c\u043d\u0435, \u0435\u0441\u043b\u0438 \u0442\u0435\u0431\u0435 \u0442\u0430\u043a \u0443\u0434\u043e\u0431\u043d\u043e.</p> <p>\u041f\u0440\u0438\u0437\u043d\u0430\u0442\u044c\u0441\u044f \u0447\u0435\u0441\u0442\u043d\u043e, \u044f \u043d\u0435 \u043e\u0436\u0438\u0434\u0430\u043b, \u0447\u0442\u043e \u0442\u044b \u0441\u043e\u0433\u043b\u0430\u0441\u0438\u0448\u044c\u0441\u044f. \u0421\u043a\u043e\u0440\u0435\u0435 \u0431\u044b\u043b\u043e \u0431\u044b \u0442\u043e, \u0447\u0442\u043e \u0442\u044b \u043d\u0430\u0439\u0434\u0451\u0448\u044c \u0438 \u0437\u0430\u0431\u043b\u043e\u043a\u0438\u0440\u0443\u0435\u0448\u044c \u0432\u0441\u0435 \u043c\u043e\u0438 \u0430\u043b\u044c\u0442\u044b, \u0447\u0442\u043e\u0431\u044b \u0432\u043e\u0442 \u0432\u043e\u043e\u0431\u0449\u0435 \u043d\u0438\u043a\u0430\u043a \u0441\u0430\u043c\u043e\u043b\u0438\u0447\u043d\u043e \u0434\u043e \u0442\u0435\u0431\u044f \u043d\u0435\u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e \u0431\u044b\u043b\u043e \u0434\u043e\u043f\u0438\u0441\u0430\u0442\u044c\u0441\u044f. \u041d\u043e \u043f\u0440\u043e\u0438\u0437\u043e\u0448\u043b\u043e \u043e\u0431\u0440\u0430\u0442\u043d\u043e\u0435, \u0438 \u044f \u0443\u0434\u0438\u0432\u043b\u0451\u043d.</p> <p>\u0412 \u043b\u044e\u0431\u043e\u043c \u0441\u043b\u0443\u0447\u0430\u0435, \u044f \u0445\u043e\u0447\u0443, \u0447\u0442\u043e\u0431\u044b \u0432\u0441\u0435 \u043d\u0430\u0441\u043b\u0430\u0434\u0438\u043b\u0438\u0441\u044c, \u0438 \u0442\u044b \u0432 \u0442\u043e\u043c \u0447\u0438\u0441\u043b\u0435.</p> <p>\u0412\u0441\u0435\u0445 \u0431\u043b\u0430\u0433, \u0436\u0434\u0443 \u043d\u0430 \u0414\u0420.</p>"},{"location":"foryou/4wonderwall/","title":"\u042d\u0442\u043e \u0442\u0435\u0431\u0435, \u041a\u043e\u0441\u0442\u044f\u043d.","text":"<p>\u042d\u0442\u043e\u0433\u043e \u043d\u0438\u043a\u0442\u043e \u043d\u0435 \u0443\u0432\u0438\u0434\u0438\u0442, \u0442\u043e\u043b\u044c\u043a\u043e \u0435\u0441\u043b\u0438 \u0442\u044b \u043d\u0435 \u043f\u0435\u0440\u0435\u0448\u043b\u0451\u0448\u044c.</p> <p>\u0414\u0430-\u0434\u0430, \u044d\u0442\u043e \u0441\u043f\u0435\u0446\u0438\u0430\u043b\u044c\u043d\u043e \u0434\u043b\u044f \u0442\u0435\u0431\u044f.</p>"},{"location":"foryou/4wonderwall/#_2","title":"\u041f\u043e\u0447\u0435\u043c\u0443 \u0442\u044b \u043f\u0440\u0438\u0433\u043b\u0430\u0448\u0451\u043d?","text":"<p>\u041f\u043e\u0442\u043e\u043c\u0443 \u044f \u0443\u0432\u0430\u0436\u0430\u044e \u0442\u0435\u0431\u044f \u043a\u0430\u043a \u0447\u0435\u043b\u043e\u0432\u0435\u043a\u0430 \u0438 \u0445\u043e\u0447\u0443 \u0432\u0438\u0434\u0435\u0442\u044c \u043d\u0430 \u0441\u0432\u043e\u0451\u043c \u043c\u0435\u0440\u043e\u043f\u0440\u0438\u044f\u0442\u0438\u0438.</p> <p>\u041f\u043e\u0442\u043e\u043c\u0443 \u0447\u0442\u043e \u0443 \u0442\u0435\u0431\u044f \u0435\u0441\u0442\u044c \u0432\u043a\u0443\u0441 \u0432 \u043c\u0443\u0437\u044b\u043a\u0435, \u0441\u0445\u043e\u0436\u0438\u0439 \u0432 \u043a\u0430\u043a\u0438\u0445-\u0442\u043e \u0447\u0435\u0440\u0442\u0430\u0445 \u0441 \u043c\u043e\u0438\u043c, \u0438 \u0442\u044b \u043c\u043e\u0436\u0435\u0448\u044c \u0434\u0430\u0436\u0435 \u0431\u044b\u0442\u044c \u0434\u0438\u0434\u0436\u0435\u0435\u043c. \u0415\u0433\u043e\u0440\u0443 \u044f \u044d\u0442\u0443 \u0440\u043e\u043b\u044c \u043d\u0435 \u0434\u0430\u043c, \u0430 \u0442\u0435\u0431\u0435 \u0432\u043f\u043e\u043b\u043d\u0435 \u043c\u043e\u0436\u043d\u043e ;)</p> <p>\u0414\u0430 \u0438 \u043f\u0440\u043e\u0441\u0442\u043e \u043f\u043e\u0442\u043e\u043c\u0443 \u0447\u0442\u043e.</p> <p>\u0412\u0441\u0435\u0445 \u0431\u043b\u0430\u0433. \u0416\u0434\u0443 \u043d\u0430 \u0414\u0420.</p>"}]}